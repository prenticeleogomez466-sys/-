{
  "name": "football-ai-copilot",
  "version": "0.2.0",
  "description": "中文足球大模型：官方数据源、实时赔率闸门、竞彩/14场推荐、自动复盘闭环",
  "type": "module",
  "scripts": {
    "credentials:check": "node src/source-credential-runner.js",
    "credentials:check:live": "node src/source-credential-runner.js --live",
    "sources:configure": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-football-data-sources.ps1",
    "sources:free-api": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-free-football-api-signups.ps1",
    "sources:repair-free": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/repair-free-football-data-sources.ps1",
    "odds:key": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/set-odds-api-key.ps1",
    "fixtures:sync": "node src/authorized-fixtures-runner.js --strict",
    "fixtures:sync:soft": "node src/authorized-fixtures-runner.js",
    "market:crawl": "node src/market-data-runner.js --crawl --strict",
    "market:crawl:soft": "node src/market-data-runner.js --crawl",
    "market:verify": "node src/market-data-runner.js --strict",
    "market:status": "node src/market-data-runner.js",
    "china:sources": "node src/china-web-source-runner.js",
    "china:sources:sync": "node src/china-web-source-runner.js --sync-fixtures",
    "crawler:realtime": "node src/realtime-crawler-runner.js",
    "crawler:realtime:strict": "node src/realtime-crawler-runner.js --require-external-odds --require-full-odds",
    "model:scorecard": "node scripts/run-model-scorecard.mjs",
    "backfill:history": "node scripts/run-backfill-history.mjs",
    "backtest:walkforward": "node scripts/run-walkforward-backtest.mjs",
    "backtest:ablation": "node scripts/run-signal-ablation.mjs",
    "weights:search": "node scripts/run-weight-search.mjs",
    "calibration:temperature": "node scripts/run-temperature-fit.mjs",
    "optimize:loop": "node scripts/run-optimize-loop.mjs",
    "recommend:coverage": "node scripts/run-selective-coverage.mjs",
    "recommend:league-reliability": "node scripts/build-league-reliability.mjs",
    "backtest:odds": "node scripts/run-walkforward-odds.mjs",
    "calibration:train": "node scripts/run-calibration-train.mjs",
    "backtest:linemove": "node scripts/run-line-movement-backtest.mjs",
    "backtest:drift": "node scripts/run-drift-backtest.mjs",
    "backtest:overunder": "node scripts/run-overunder-backtest.mjs",
    "sync:injuries": "node scripts/sync-free-injuries.mjs",
    "sync:injuries:sofascore": "node scripts/sync-sofascore-injuries.mjs",
    "sources:probe": "node scripts/probe-free-sources.mjs",
    "analyze:deep": "node scripts/run-analyze-deep.mjs",
    "jingcai:daily": "node scripts/jingcai-daily.mjs",
    "analog:report": "node scripts/analog-report.mjs",
    "report:html": "node scripts/render-recommendation-html.mjs",
    "daily": "node src/daily-evolution.js",
    "daily:fallback": "node scripts/daily-with-fallback.mjs",
    "daily:allow-missing": "node src/daily-evolution.js --allow-missing-odds",
    "daily:no-web": "node src/daily-evolution.js --allow-missing-odds",
    "sync:artifacts": "node src/artifact-sync.js",
    "auto:health": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-football-automation.ps1 -Mode health",
    "auto:daily": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-football-automation.ps1 -Mode daily",
    "auto:recap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-football-automation.ps1 -Mode recap",
    "auto:weekly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-football-automation.ps1 -Mode weekly",
    "auto:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-football-automation.ps1 -Mode all",
    "auto:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-football-automation-tasks.ps1",
    "wechat:reconnect": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reconnect-wechat-server.ps1",
    "recommend:audit": "node src/recommendation-audit.js",
    "recap:daily": "node src/daily-recap.js",
    "recap:health": "node src/recap-automation-health.js",
    "backtest:evolution": "node src/evolution-backtest.js",
    "sources:audit": "node src/data-source-registry.js",
    "sources:vet": "node src/source-vetting.js",
    "freeodds:audit": "node src/free-odds-source-registry.js",
    "wechat:check": "node src/wechat-smoke.js",
    "start": "node src/server.js",
    "test": "node --test",
    "model:audit": "node src/model-structure-audit.js",
    "model:top-tier-audit": "node src/top-tier-model-audit.js",
    "model:defect-audit": "node src/model-defect-audit.js",
    "model:stage-audit": "node src/model-stage-audit.js",
    "model:capability-audit": "node src/model-capability-registry.js",
    "advanced:sync": "node src/advanced-data-runner.js",
    "standard:check": "node src/data-completeness-standard-runner.js",
    "dc:fit": "node -e \"import('./src/dixon-coles-engine.js').then(m => { const f = m.fitFromFixtureStore(); console.log(JSON.stringify({ usable: f.usable, matches: f.matches, teams: Object.keys(f.teams).length, baseRate: f.baseRate }, null, 2)); })\"",
    "dc:predict": "node -e \"import('./src/dixon-coles-engine.js').then(m => { const f = m.fitFromFixtureStore(); const args = process.argv.slice(2); if (args.length < 2) { console.log('用法: npm run dc:predict -- 主队 客队'); return; } console.log(JSON.stringify(m.predictFromFitted(f, { homeTeam: args[0], awayTeam: args[1] }), null, 2)); })\"",
    "metrics:trend": "node -e \"import('./src/daily-metrics-trend.js').then(m => console.log(JSON.stringify({ rolling7: m.rollingMetrics(7), rolling14: m.rollingMetrics(14), rolling30: m.rollingMetrics(30), drift: m.detectDrift() }, null, 2)))\"",
    "signal:weights": "node -e \"import('./src/signal-weight-tuner.js').then(m => console.log(JSON.stringify(m.buildSignalWeightsProfile(), null, 2)))\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "undici": "^8.3.0"
  }
}
